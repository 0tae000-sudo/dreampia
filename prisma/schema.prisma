// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             Int        @id @default(autoincrement())
  email          String?    @unique
  password       String
  name           String
  phone          String     @unique
  howcome        String?
  graduationYear String?
  schoolName     String?
  major          String?
  introduction   String?
  role           String?
  position       String?
  isTeacher      Boolean?
  isMentor       Boolean?
  isAdmin        Boolean?
  postcode       String?
  address        String?
  detailAddress  String?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  SMSToken       SMSToken[]
  mentorProfile  MentorProfile?
  agreementConsents AgreementConsent[]
  
}

model MentorProfile {
  id         Int         @id @default(autoincrement())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int         @unique
  jobs       MentorJob[]
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
}

model MentorJob {
  id           Int                 @id @default(autoincrement())
  profile      MentorProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId    Int
  title        String
  order        Int
  careers      MentorCareer[]
  certificates MentorCertificate[]
  awards       MentorAward[]
  lectures     MentorLecture[]
}

model MentorCareer {
  id        Int       @id @default(autoincrement())
  job       MentorJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     Int
  period    String?
  role      String?
  company   String?
}

model MentorCertificate {
  id      Int       @id @default(autoincrement())
  job     MentorJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId   Int
  date    String?
  name    String?
  issuer  String?
}

model MentorAward {
  id           Int       @id @default(autoincrement())
  job          MentorJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId        Int
  date         String?
  title        String?
  organization String?
}

model MentorLecture {
  id           Int       @id @default(autoincrement())
  job          MentorJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId        Int
  period       String?
  title        String?
  organization String?
}

model SMSToken {
  id         Int      @id @default(autoincrement())
  phone      String
  token      String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model PhoneVerificationToken {
  id         Int      @id @default(autoincrement())
  phone      String   @unique
  token      String
  expiresAt  DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Agreement {
  id         Int                @id @default(autoincrement())
  code       String             @unique
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt
  versions   AgreementVersion[]
}

model AgreementVersion {
  id           Int               @id @default(autoincrement())
  agreement    Agreement         @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId  Int
  version      String
  title        String
  body         String
  isRequired   Boolean           @default(true)
  role         AgreementRole     @default(ALL)
  isActive     Boolean           @default(true)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  consents     AgreementConsent[]

  @@unique([agreementId, version])
}

model AgreementConsent {
  id                 Int              @id @default(autoincrement())
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             Int
  agreementVersion   AgreementVersion @relation(fields: [agreementVersionId], references: [id], onDelete: Cascade)
  agreementVersionId Int
  agreedAt           DateTime         @default(now())
}

model Job {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model EventApplication {
  id                      Int                   @id @default(autoincrement())
  schoolName              String
  schoolLevel             SchoolLevel
  postcode                String
  address                 String
  detailAddress           String
  managerName             String
  managerPosition         String
  managerPhone            String
  managerEmail            String
  adminName               String
  adminPosition           String
  adminPhone              String
  adminEmail              String
  eventName               String
  programType             ProgramType
  eventDate               DateTime
  targetGrades            Json
  totalStudents           Int
  studentChangeType       StudentChangeType
  mentorRequestCount      Int
  mentorPreference        String?
  providedItems           Json
  expectedQuote           String?
  inquiry                 String?
  timeSlots               EventTimeSlot[]
  created_at              DateTime              @default(now())
  updated_at              DateTime              @updatedAt
}

model EventTimeSlot {
  id              Int               @id @default(autoincrement())
  application     EventApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId   Int
  period          Int
  startHour       Int
  startMinute     Int
  endHour         Int
  endMinute       Int
}

enum AgreementRole {
  ALL
  TEACHER
  MENTOR
}

enum SchoolLevel {
  ELEMENTARY
  MIDDLE
  HIGH
  INSTITUTE
}

enum ProgramType {
  JOB_LECTURE
  JOB_EXPERIENCE
  STUDY_CONCERT
  JOB_FAIR
  CAREER_CAMP
  NEW_INDUSTRY
  JUNGRANG_ONE_DAY
  CAREER_CONCERT
  CAREER_PLAY
  DIGITAL_CAMP
}

enum StudentChangeType {
  CHANGE_PER_PERIOD
  NO_CHANGE
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String   // 제목
  content   String   // 본문
  author    String   // 작성자 (예: 마스)
  category  String?  // 카테고리 (예: 교사, 일반)
  views     Int      @default(0) // 조회수
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}


